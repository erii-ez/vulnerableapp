{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=VulnerableDb;Trusted_Connection=true;"
  },
  "Serilog": {
      "MinimumLevel": {
        "Default": "Information",
        "Override": {
          "Microsoft": "Warning"
        }
      },
      "WriteTo": [
        {
          "Name": "Seq",
          "Args": { "serverUrl": "http://localhost:5341" }
        }
      ],
      "Enrich": [ "FromLogContext", "WithMachineName" ]
    }
  
}